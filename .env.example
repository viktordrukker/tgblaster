# --- Telegram API credentials ---
# Get these from https://my.telegram.org → API development tools.
# Each user-session uses exactly ONE pair (api_id + api_hash) tied to
# the phone number you log in with.
#
# After copying this file to `.env` and filling values, run:
#     chmod 600 .env
# so only your user can read the credentials.
TG_API_ID=
TG_API_HASH=

# Session file stem (no extension). The actual file lives at
# ./sessions/<TG_SESSION_NAME>.session after login.
TG_SESSION_NAME=tg_session

# --- Sending pacing (conservative defaults) ---
# Telegram limits cold DMs per day aggressively. 300 is safe for a
# warmed-up account; new accounts should start closer to 20-50.
DAILY_CAP=300

# Random delay between sends (seconds). 30-90s feels human.
MIN_DELAY_SEC=30
MAX_DELAY_SEC=90

# Every N messages, insert a longer pause — mimics natural conversation
# breaks and keeps per-hour rate in a safe range.
LONG_PAUSE_EVERY=40
LONG_PAUSE_MIN_SEC=600
LONG_PAUSE_MAX_SEC=900

# --- UI access control (optional) ---
# Set this to require a password to open the Streamlit UI. Leave empty
# to disable (default). Prefer a long random value; compared with
# `secrets.compare_digest` (constant-time). When deploying publicly you
# should ALSO front the app with a reverse proxy that enforces TLS and
# basic-auth — see docs/DEPLOYMENT.md.
TGBLASTER_UI_PASSWORD=
